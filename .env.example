# HealthyBite Environment Variables
# Copy this file to .env.local for local development.
# Add these same keys in Vercel → Settings → Environment Variables.

# Supabase (required) — get from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini AI (optional — fallback engine used if not set)
GEMINI_API_KEY=your-gemini-api-key-here
