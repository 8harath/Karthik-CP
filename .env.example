# HealthyBite Environment Variables
# Copy this file to .env.local for local development.
# Add these same keys in Vercel → Settings → Environment Variables.

# Supabase (required) — get from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq AI (optional — fallback engine used if not set)
# Get free API key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
